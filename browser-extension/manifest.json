{
  "manifest_version": 3,
  "name": "PHM Web Clipper",
  "version": "0.1.0",
  "description": "Save selected text from web pages to Personal Highlight Manager.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "phm-web-clipper@highlight-manager.local",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "Save to PHM",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg"
    }
  },
  "options_page": "options.html"
}
